# Copy to .env and fill in. .env is gitignored.

# --- Tracking API (provided in the brief) ---
TRACKING_API_BASE=https://xteam-ho-2920.wasmer.app
TRACKING_API_KEY=xt2920-k7q2m9wz

# --- LLM classifier ---
# LLM_PROVIDER selects the classifier backend:
#   mock      -> deterministic, rule-based, no network/key needed (default)
#   anthropic -> real Claude call; requires ANTHROPIC_API_KEY below
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
