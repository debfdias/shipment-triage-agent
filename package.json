{
  "name": "shipment-triage-agent",
  "version": "0.1.0",
  "description": "First-pass agent that triages a multi-carrier shipment-status feed: flags exceptions, enriches via a flaky tracking API, classifies with an LLM, and emits EDI 214 escalations.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "triage": "tsx src/cli.ts",
    "serve": "tsx src/api/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
